# ASR credentials
ASR_API_KEY=
ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Text polish credentials
TEXT_POLISH_API_KEY=
TEXT_POLISH_BASE_URL=

# Legacy compatibility keys (optional)
# API_KEY=
# BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model selection
ASR_NON_STREAM_MODEL=qwen3-asr-flash
ASR_REALTIME_MODEL=qwen3-asr-flash-realtime
ASR_TEXT_POLISH_MODEL=qwen3.5-flash
TEXT_POLISH_OUTPUT_KEY=text

# App behavior
ASR_DEFAULT_MODE=1
ASR_LOG_LEVEL=INFO
ASR_HOTKEY_MODE=hold
ASR_PRIMARY_HOTKEY=caps lock
ASR_SECONDARY_HOTKEY=f8
ASR_INPUT_SOURCE_TYPE=local_mic
ASR_OPTIMIZATION_LEVEL=normal
